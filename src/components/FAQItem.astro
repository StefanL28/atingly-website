---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="faq-item border-b border-border">
  <button
    class="faq-trigger w-full flex items-center justify-between py-5 text-left group cursor-pointer"
    aria-expanded="false"
  >
    <span class="text-base lg:text-lg font-semibold text-text-primary group-hover:text-primary-dark transition-colors pr-4">{question}</span>
    <div class="faq-icon shrink-0 w-8 h-8 rounded-full bg-surface-alt flex items-center justify-center transition-all duration-300 group-hover:bg-primary/15">
      <svg class="w-4 h-4 text-primary-dark transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19" class="faq-vertical"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </div>
  </button>
  <div class="faq-content overflow-hidden transition-all duration-300" style="max-height: 0;">
    <p class="pb-5 text-text-secondary leading-relaxed">{answer}</p>
  </div>
</div>
