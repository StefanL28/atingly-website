---
import Button from './ui/Button.astro';
import AvatarStack from './AvatarStack.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero-gradient relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-32">
  <!-- Decorative elements -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary/8 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 bg-secondary/6 rounded-full blur-3xl"></div>
  <div class="absolute top-1/2 left-1/3 w-60 h-60 bg-navy/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-[55%_45%] gap-12 lg:gap-8 items-center">
      <!-- Left Column -->
      <div class="max-w-xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm rounded-full border border-border shadow-sm mb-8" data-animate="fade-up">
          <span class="text-lg">🇨🇮</span>
          <span class="text-sm font-semibold text-text-secondary">{t('hero.badge')}</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl lg:text-[64px] font-extrabold leading-[1.1] tracking-tight mb-6" data-animate="fade-up">
          {t('hero.headline1')}
          <span class="text-gradient">{t('hero.headline2')}</span>
          {t('hero.headline3')}
          <span class="text-gradient">{t('hero.headline4')}</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-8 max-w-lg" data-animate="fade-up">
          {t('hero.subtitle')}
        </p>

        <!-- CTA -->
        <div class="mb-10" data-animate="fade-up">
          <Button href="#telecharger" size="lg">
            {t('hero.cta')}
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>

        <!-- Avatar Stack -->
        <div data-animate="fade-up">
          <AvatarStack text={t('hero.avatarText')} />
        </div>
      </div>

      <!-- Right Column — Phone Mockup -->
      <div class="relative flex justify-center lg:justify-end" data-animate="slide-in-right">
        <!-- Decorative blob behind phone -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 lg:w-[420px] lg:h-[420px] bg-primary/10 blob animate-pulse" style="animation-duration: 8s;"></div>

        <!-- Phone Image -->
        <img
          src="/hero-phone.png"
          alt="Swoop app"
          class="relative z-10 w-[280px] lg:w-[320px] drop-shadow-2xl"
        />

        <!-- Floating discount card -->
        <div class="absolute -left-4 lg:-left-12 bottom-32 bg-white rounded-2xl p-4 shadow-xl shadow-primary/10 border border-border z-20" data-animate="float">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-surface-alt rounded-xl flex items-center justify-center">
              <span class="text-2xl">💰</span>
            </div>
            <div>
              <p class="text-xs text-text-secondary font-medium">{t('hero.saveUpTo')}</p>
              <p class="text-2xl font-extrabold text-gradient">50%</p>
            </div>
          </div>
        </div>

        <!-- Floating avatar -->
        <div class="absolute -right-2 lg:right-4 top-20 z-20" data-animate="float" style="animation-delay: 1s;">
          <div class="w-14 h-14 brand-gradient rounded-full flex items-center justify-center shadow-lg shadow-secondary/20 border-3 border-white">
            <span class="text-lg">⭐</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  [data-animate="float"] {
    animation: float 4s ease-in-out infinite;
  }
</style>
