---
import Button from './ui/Button.astro';
import AvatarStack from './AvatarStack.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero-gradient relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-32">
  <!-- Decorative elements -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary/8 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 bg-secondary/6 rounded-full blur-3xl"></div>
  <div class="absolute top-1/2 left-1/3 w-60 h-60 bg-navy/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-[55%_45%] gap-12 lg:gap-8 items-center">
      <!-- Left Column -->
      <div class="max-w-xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur-sm rounded-full border border-border shadow-sm mb-8" data-animate="fade-up">
          <span class="text-lg">🇨🇮</span>
          <span class="text-sm font-semibold text-text-secondary">{t('hero.badge')}</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl lg:text-[64px] font-extrabold leading-[1.1] tracking-tight mb-6" data-animate="fade-up">
          {t('hero.headline1')}
          <span class="text-gradient">{t('hero.headline2')}</span>
          {t('hero.headline3')}
          <span class="text-gradient">{t('hero.headline4')}</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-8 max-w-lg" data-animate="fade-up">
          {t('hero.subtitle')}
        </p>

        <!-- CTA -->
        <div class="mb-10" data-animate="fade-up">
          <Button href="#telecharger" size="lg">
            {t('hero.cta')}
            <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>

        <!-- Avatar Stack -->
        <div data-animate="fade-up">
          <AvatarStack text={t('hero.avatarText')} />
        </div>
      </div>

      <!-- Right Column — Phone Mockup -->
      <div class="relative flex justify-center lg:justify-end" data-animate="slide-in-right">
        <!-- Decorative blob behind phone -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 lg:w-[420px] lg:h-[420px] bg-primary/10 blob animate-pulse" style="animation-duration: 8s;"></div>

        <!-- Phone Frame -->
        <div class="relative z-10 w-[280px] lg:w-[320px]">
          <div class="relative bg-text-primary rounded-[3rem] p-3 shadow-2xl shadow-navy/20">
            <!-- Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-text-primary rounded-b-2xl z-20"></div>

            <!-- Screen -->
            <div class="bg-white rounded-[2.25rem] overflow-hidden aspect-[9/19.5]">
              <!-- Status Bar with gradient -->
              <div class="brand-gradient px-6 pt-8 pb-4">
                <div class="flex items-center justify-between text-white mb-4">
                  <span class="text-xs font-semibold opacity-80">9:41</span>
                  <div class="flex gap-1">
                    <div class="w-4 h-2 bg-white/60 rounded-sm"></div>
                    <div class="w-4 h-2 bg-white/40 rounded-sm"></div>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
                    <img src="/logo.png" alt="Swoop" class="w-6 h-6" />
                  </div>
                  <div>
                    <p class="text-white font-bold text-sm">Swoop</p>
                    <p class="text-white/70 text-xs">{t('hero.online')}</p>
                  </div>
                </div>
              </div>

              <!-- Chat Messages -->
              <div class="p-4 space-y-3 bg-gray-50">
                <!-- Bot message 1 -->
                <div class="flex gap-2">
                  <div class="w-6 h-6 brand-gradient rounded-full shrink-0 mt-1 flex items-center justify-center">
                    <span class="text-white text-[8px] font-bold">S</span>
                  </div>
                  <div class="bg-white rounded-2xl rounded-tl-sm px-3 py-2 shadow-sm max-w-[85%] border border-border">
                    <p class="text-[10px] text-text-primary font-medium">{t('hero.chatGreeting')}</p>
                  </div>
                </div>

                <!-- Deal Card 1 -->
                <div class="ml-8 bg-white rounded-xl p-2.5 shadow-sm border border-border">
                  <div class="flex items-center gap-2 mb-1.5">
                    <div class="w-8 h-8 bg-primary/15 rounded-lg flex items-center justify-center">
                      <span class="text-sm">🍕</span>
                    </div>
                    <div class="flex-1">
                      <p class="text-[9px] font-bold text-text-primary">Pizza Palace</p>
                      <p class="text-[8px] text-text-secondary">Cocody, Abidjan</p>
                    </div>
                    <div class="bg-secondary text-white text-[8px] font-bold px-2 py-0.5 rounded-full">-30%</div>
                  </div>
                </div>

                <!-- Deal Card 2 -->
                <div class="ml-8 bg-white rounded-xl p-2.5 shadow-sm border border-border">
                  <div class="flex items-center gap-2 mb-1.5">
                    <div class="w-8 h-8 bg-accent/20 rounded-lg flex items-center justify-center">
                      <span class="text-sm">👗</span>
                    </div>
                    <div class="flex-1">
                      <p class="text-[9px] font-bold text-text-primary">Mode Abi</p>
                      <p class="text-[8px] text-text-secondary">Plateau, Abidjan</p>
                    </div>
                    <div class="bg-primary-dark text-white text-[8px] font-bold px-2 py-0.5 rounded-full">-50%</div>
                  </div>
                </div>

                <!-- User reply -->
                <div class="flex justify-end">
                  <div class="brand-gradient text-white rounded-2xl rounded-tr-sm px-3 py-2 max-w-[75%]">
                    <p class="text-[10px] font-medium">{t('hero.chatReply')}</p>
                  </div>
                </div>

                <!-- Bot response -->
                <div class="flex gap-2">
                  <div class="w-6 h-6 brand-gradient rounded-full shrink-0 mt-1 flex items-center justify-center">
                    <span class="text-white text-[8px] font-bold">S</span>
                  </div>
                  <div class="bg-white rounded-2xl rounded-tl-sm px-3 py-2 shadow-sm max-w-[85%] border border-border">
                    <p class="text-[10px] text-text-primary font-medium">{t('hero.chatPromo')}</p>
                  </div>
                </div>
              </div>

              <!-- Input bar -->
              <div class="px-3 py-2 bg-white border-t border-border">
                <div class="flex items-center gap-2">
                  <div class="flex-1 bg-surface-alt rounded-full px-3 py-1.5">
                    <p class="text-[9px] text-text-secondary">{t('hero.writeMessage')}</p>
                  </div>
                  <div class="w-7 h-7 brand-gradient rounded-full flex items-center justify-center">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="white">
                      <path d="M2 21L23 12L2 3V10L17 12L2 14V21Z"/>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Home indicator -->
          <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-24 h-1 bg-white/30 rounded-full"></div>
        </div>

        <!-- Floating discount card -->
        <div class="absolute -left-4 lg:-left-12 bottom-32 bg-white rounded-2xl p-4 shadow-xl shadow-primary/10 border border-border z-20" data-animate="float">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-surface-alt rounded-xl flex items-center justify-center">
              <span class="text-2xl">💰</span>
            </div>
            <div>
              <p class="text-xs text-text-secondary font-medium">{t('hero.saveUpTo')}</p>
              <p class="text-2xl font-extrabold text-gradient">50%</p>
            </div>
          </div>
        </div>

        <!-- Floating avatar -->
        <div class="absolute -right-2 lg:right-4 top-20 z-20" data-animate="float" style="animation-delay: 1s;">
          <div class="w-14 h-14 brand-gradient rounded-full flex items-center justify-center shadow-lg shadow-secondary/20 border-3 border-white">
            <span class="text-lg">⭐</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  [data-animate="float"] {
    animation: float 4s ease-in-out infinite;
  }
</style>
