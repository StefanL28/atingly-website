---
import SectionHeading from './ui/SectionHeading.astro';
import FAQItem from './FAQItem.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqItems = [
  { question: t('faq.0.question'), answer: t('faq.0.answer') },
  { question: t('faq.1.question'), answer: t('faq.1.answer') },
  { question: t('faq.2.question'), answer: t('faq.2.answer') },
  { question: t('faq.3.question'), answer: t('faq.3.answer') },
  { question: t('faq.4.question'), answer: t('faq.4.answer') },
  { question: t('faq.5.question'), answer: t('faq.5.answer') },
];
---

<section class="py-20 lg:py-32 bg-background" id="faq">
  <div class="max-w-3xl mx-auto px-6 lg:px-8">
    <SectionHeading subtitle={t('faq.subtitle')}>
      {t('faq.heading')} <span class="text-gradient">{t('faq.headingHighlight')}</span>
    </SectionHeading>

    <div class="divide-y-0" data-animate="fade-up">
      {faqItems.map(item => (
        <FAQItem question={item.question} answer={item.answer} />
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item?.querySelector('.faq-content') as HTMLElement;
      const vertical = item?.querySelector('.faq-vertical') as SVGLineElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all other items
      document.querySelectorAll('.faq-item').forEach(otherItem => {
        if (otherItem !== item) {
          const otherContent = otherItem.querySelector('.faq-content') as HTMLElement;
          const otherTrigger = otherItem.querySelector('.faq-trigger');
          const otherVertical = otherItem.querySelector('.faq-vertical') as SVGLineElement;
          if (otherContent) otherContent.style.maxHeight = '0';
          otherTrigger?.setAttribute('aria-expanded', 'false');
          if (otherVertical) otherVertical.style.transform = '';
        }
      });

      if (isOpen) {
        content.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        if (vertical) vertical.style.transform = '';
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        if (vertical) vertical.style.transform = 'rotate(90deg)';
      }
    });
  });
</script>

<style>
  .faq-vertical {
    transform-origin: center;
    transition: transform 0.3s ease;
  }
</style>
