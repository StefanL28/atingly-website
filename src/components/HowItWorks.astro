---
import SectionHeading from './ui/SectionHeading.astro';

const steps = [
  {
    number: '01',
    title: 'Telechargez',
    description: "Installez l'application Swoop gratuitement depuis l'App Store ou Google Play.",
    icon: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
  },
  {
    number: '02',
    title: 'Recevez',
    description: 'Des offres personnalisees arrivent directement dans votre chat. Pas de spam, que du bon.',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  },
  {
    number: '03',
    title: 'Economisez',
    description: 'Utilisez vos codes promo chez nos partenaires et profitez de reductions incroyables.',
    icon: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  },
];
---

<section class="py-20 lg:py-32 bg-background" id="comment-ca-marche">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <SectionHeading subtitle="Commencez a economiser en trois etapes simples.">
      Comment ca <span class="text-primary">marche</span>
    </SectionHeading>

    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-24 left-[20%] right-[20%] h-px bg-gradient-to-r from-primary/20 via-primary/40 to-primary/20"></div>

      {steps.map((step) => (
        <div class="relative text-center" data-animate="fade-up">
          <!-- Step number -->
          <div class="relative z-10 w-20 h-20 mx-auto mb-6 bg-primary/10 rounded-2xl flex items-center justify-center">
            <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={step.icon} />
            </svg>
          </div>
          <span class="inline-block text-xs font-bold text-primary bg-primary/10 px-3 py-1 rounded-full mb-3">{step.number}</span>
          <h3 class="text-xl font-bold text-text-primary mb-2">{step.title}</h3>
          <p class="text-text-secondary leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
