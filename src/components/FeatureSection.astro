---
interface Props {
  title: string;
  description: string;
  color: 'primary' | 'secondary' | 'accent';
  reverse?: boolean;
  screenContent?: 'chat' | 'deals' | 'map';
}

const { title, description, color, reverse = false, screenContent = 'chat' } = Astro.props;

const colorMap = {
  primary: { bg: 'bg-primary/10', blob: 'bg-primary/15', accent: 'bg-primary', text: 'text-primary' },
  secondary: { bg: 'bg-secondary/10', blob: 'bg-secondary/15', accent: 'bg-secondary', text: 'text-secondary' },
  accent: { bg: 'bg-accent/10', blob: 'bg-accent/15', accent: 'bg-accent', text: 'text-accent' },
};

const colors = colorMap[color];
---

<div class={`grid lg:grid-cols-2 gap-12 lg:gap-20 items-center ${reverse ? 'direction-reverse' : ''}`}>
  <!-- Phone Mockup -->
  <div class={`relative flex justify-center ${reverse ? 'lg:order-2' : ''}`} data-animate="fade-up">
    <!-- Blob -->
    <div class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 lg:w-80 lg:h-80 ${colors.blob} blob`}></div>

    <!-- Phone -->
    <div class="relative z-10 w-[240px] lg:w-[260px]">
      <div class="bg-text-primary rounded-[2.5rem] p-2.5 shadow-xl">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-text-primary rounded-b-xl z-20"></div>
        <div class="bg-white rounded-[2rem] overflow-hidden aspect-[9/19.5]">
          {screenContent === 'chat' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accent} px-4 pt-6 pb-3`}>
                <p class="text-white font-bold text-xs">Swoop Chat</p>
                <p class="text-white/70 text-[10px]">3 nouvelles offres</p>
              </div>
              <div class="flex-1 p-3 space-y-2 bg-gray-50">
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm">
                  <p class="text-[9px] font-semibold text-text-primary">Nouvelle offre pour vous !</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">Restaurant Le Gourmet — 25% de reduction</p>
                </div>
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm">
                  <p class="text-[9px] font-semibold text-text-primary">Offre flash ⚡</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">Supermarche Express — 15% sur tout</p>
                </div>
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm">
                  <p class="text-[9px] font-semibold text-text-primary">Recommande pour vous</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">Salon Beaute Plus — Soin gratuit</p>
                </div>
              </div>
            </div>
          )}
          {screenContent === 'deals' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accent} px-4 pt-6 pb-3`}>
                <p class="text-white font-bold text-xs">Pour vous</p>
                <p class="text-white/70 text-[10px]">Basé sur vos préférences</p>
              </div>
              <div class="flex-1 p-3 space-y-2 bg-gray-50">
                {['🍽️ Restaurants', '👗 Mode', '💇 Beaute'].map((cat) => (
                  <div class="bg-white rounded-xl p-2.5 shadow-sm">
                    <div class="flex items-center justify-between">
                      <span class="text-[9px] font-semibold text-text-primary">{cat}</span>
                      <span class={`text-[8px] font-bold ${colors.text} ${colors.bg} px-2 py-0.5 rounded-full`}>Nouveau</span>
                    </div>
                    <div class="flex gap-1 mt-1.5">
                      <div class={`h-1 flex-1 ${colors.accent} rounded-full opacity-60`}></div>
                      <div class={`h-1 w-8 ${colors.bg} rounded-full`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
          {screenContent === 'map' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accent} px-4 pt-6 pb-3`}>
                <p class="text-white font-bold text-xs">Pres de vous</p>
                <p class="text-white/70 text-[10px]">12 commerces partenaires</p>
              </div>
              <div class="flex-1 bg-gray-100 relative">
                <!-- Simplified map placeholder -->
                <div class="absolute inset-3 bg-gray-200 rounded-xl overflow-hidden">
                  <div class="w-full h-full relative">
                    <!-- Roads -->
                    <div class="absolute top-1/2 left-0 right-0 h-px bg-gray-300"></div>
                    <div class="absolute top-0 bottom-0 left-1/3 w-px bg-gray-300"></div>
                    <div class="absolute top-0 bottom-0 left-2/3 w-px bg-gray-300"></div>
                    <!-- Pins -->
                    <div class={`absolute top-1/4 left-1/4 w-5 h-5 ${colors.accent} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                      <span class="text-white text-[6px] font-bold">1</span>
                    </div>
                    <div class={`absolute top-1/3 left-1/2 w-5 h-5 ${colors.accent} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                      <span class="text-white text-[6px] font-bold">2</span>
                    </div>
                    <div class={`absolute top-2/3 left-3/5 w-5 h-5 ${colors.accent} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                      <span class="text-white text-[6px] font-bold">3</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="p-2 bg-white">
                <div class="bg-gray-50 rounded-lg p-2 flex items-center gap-2">
                  <div class={`w-6 h-6 ${colors.accent} rounded-full flex items-center justify-center`}>
                    <span class="text-white text-[8px]">📍</span>
                  </div>
                  <p class="text-[8px] text-text-secondary font-medium">Abidjan, Cote d'Ivoire</p>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Text Content -->
  <div class={`${reverse ? 'lg:order-1' : ''}`} data-animate="fade-up">
    <div class={`inline-flex items-center gap-2 px-3 py-1.5 ${colors.bg} rounded-full mb-6`}>
      <div class={`w-2 h-2 ${colors.accent} rounded-full`}></div>
      <span class={`text-xs font-semibold ${colors.text}`}>Fonctionnalite</span>
    </div>
    <h3 class="text-3xl md:text-4xl font-bold text-text-primary tracking-tight mb-4">{title}</h3>
    <p class="text-lg text-text-secondary leading-relaxed max-w-md">{description}</p>
  </div>
</div>
