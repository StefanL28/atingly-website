---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  color: 'primary' | 'secondary' | 'accent';
  reverse?: boolean;
  screenContent?: 'chat' | 'deals' | 'map';
}

const { title, description, color, reverse = false, screenContent = 'chat' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const colorMap = {
  primary: { bg: 'bg-primary/10', blob: 'bg-primary/15', accent: 'brand-gradient', accentBg: 'bg-primary', text: 'text-primary' },
  secondary: { bg: 'bg-secondary/10', blob: 'bg-secondary/12', accent: 'bg-secondary', accentBg: 'bg-secondary', text: 'text-secondary' },
  accent: { bg: 'bg-navy/10', blob: 'bg-navy/12', accent: 'bg-navy', accentBg: 'bg-navy', text: 'text-navy' },
};

const colors = colorMap[color];

const categories = [t('cat.restaurants'), t('cat.fashion'), t('cat.beauty')];
---

<div class={`grid lg:grid-cols-2 gap-12 lg:gap-20 items-center ${reverse ? 'direction-reverse' : ''}`}>
  <!-- Phone Mockup -->
  <div class={`relative flex justify-center ${reverse ? 'lg:order-2' : ''}`} data-animate="fade-up">
    <!-- Blob -->
    <div class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 lg:w-80 lg:h-80 ${colors.blob} blob`}></div>

    <!-- Phone -->
    <div class="relative z-10 w-[240px] lg:w-[260px]">
      <!-- Left: Action button -->
      <div class="absolute -left-[3px] top-[19%] w-[3px] h-5 bg-text-primary rounded-l-[3px]"></div>
      <!-- Left: Volume Up -->
      <div class="absolute -left-[3px] top-[27%] w-[3px] h-9 bg-text-primary rounded-l-[3px]"></div>
      <!-- Left: Volume Down -->
      <div class="absolute -left-[3px] top-[38%] w-[3px] h-9 bg-text-primary rounded-l-[3px]"></div>
      <!-- Right: Power button -->
      <div class="absolute -right-[3px] top-[27%] w-[3px] h-12 bg-text-primary rounded-r-[3px]"></div>

      <div class="bg-text-primary rounded-[2.8rem] p-[6px] shadow-2xl">
        <div class="bg-white rounded-[2.4rem] overflow-hidden aspect-[9/19.5] relative">
          <!-- Dynamic Island -->
          <div class="absolute top-2.5 left-1/2 -translate-x-1/2 w-[68px] h-[18px] bg-text-primary rounded-full z-30"></div>
          {screenContent === 'chat' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accent} px-4 pt-8 pb-3`}>
                <p class="text-white font-bold text-xs">{t('screen.chat.title')}</p>
                <p class="text-white/70 text-[10px]">{t('screen.chat.subtitle')}</p>
              </div>
              <div class="flex-1 p-3 space-y-2 bg-gray-50">
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm border border-border">
                  <p class="text-[9px] font-semibold text-text-primary">{t('screen.chat.offer1.title')}</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">{t('screen.chat.offer1.desc')}</p>
                </div>
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm border border-border">
                  <p class="text-[9px] font-semibold text-text-primary">{t('screen.chat.offer2.title')}</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">{t('screen.chat.offer2.desc')}</p>
                </div>
                <div class="bg-white rounded-xl px-3 py-2 shadow-sm border border-border">
                  <p class="text-[9px] font-semibold text-text-primary">{t('screen.chat.offer3.title')}</p>
                  <p class="text-[8px] text-text-secondary mt-0.5">{t('screen.chat.offer3.desc')}</p>
                </div>
              </div>
            </div>
          )}
          {screenContent === 'deals' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accentBg} px-4 pt-8 pb-3`}>
                <p class="text-white font-bold text-xs">{t('screen.deals.title')}</p>
                <p class="text-white/70 text-[10px]">{t('screen.deals.subtitle')}</p>
              </div>
              <div class="flex-1 p-3 space-y-2 bg-gray-50">
                {categories.map((cat) => (
                  <div class="bg-white rounded-xl p-2.5 shadow-sm border border-border">
                    <div class="flex items-center justify-between">
                      <span class="text-[9px] font-semibold text-text-primary">{cat}</span>
                      <span class={`text-[8px] font-bold ${colors.text} ${colors.bg} px-2 py-0.5 rounded-full`}>{t('screen.deals.new')}</span>
                    </div>
                    <div class="flex gap-1 mt-1.5">
                      <div class={`h-1 flex-1 ${colors.accentBg} rounded-full opacity-60`}></div>
                      <div class={`h-1 w-8 ${colors.bg} rounded-full`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
          {screenContent === 'map' && (
            <div class="h-full flex flex-col">
              <div class={`${colors.accentBg} px-4 pt-8 pb-3`}>
                <p class="text-white font-bold text-xs">{t('screen.map.title')}</p>
                <p class="text-white/70 text-[10px]">{t('screen.map.subtitle')}</p>
              </div>
              <div class="flex-1 relative overflow-hidden">
                <img src="/maps/abidjan-map.svg" alt="Map of Abidjan" class="w-full h-full object-cover" />
                <!-- Pins -->
                <div class={`absolute top-1/4 left-1/4 w-5 h-5 ${colors.accentBg} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                  <span class="text-white text-[6px] font-bold">1</span>
                </div>
                <div class={`absolute top-1/3 left-1/2 w-5 h-5 ${colors.accentBg} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                  <span class="text-white text-[6px] font-bold">2</span>
                </div>
                <div class={`absolute top-2/3 left-3/5 w-5 h-5 ${colors.accentBg} rounded-full border-2 border-white shadow flex items-center justify-center`}>
                  <span class="text-white text-[6px] font-bold">3</span>
                </div>
              </div>
              <div class="p-2 bg-white">
                <div class="bg-surface-alt rounded-lg p-2 flex items-center gap-2">
                  <div class={`w-6 h-6 ${colors.accentBg} rounded-full flex items-center justify-center`}>
                    <span class="text-white text-[8px]">📍</span>
                  </div>
                  <p class="text-[8px] text-text-secondary font-medium">{t('footer.location')}</p>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Text Content -->
  <div class={`${reverse ? 'lg:order-1' : ''}`} data-animate="fade-up">
    <div class={`inline-flex items-center gap-2 px-3 py-1.5 ${colors.bg} rounded-full mb-6`}>
      <div class={`w-2 h-2 ${colors.accentBg} rounded-full`}></div>
      <span class={`text-xs font-semibold ${colors.text}`}>{t('features.badge')}</span>
    </div>
    <h3 class="text-3xl md:text-4xl font-bold text-text-primary tracking-tight mb-4">{title}</h3>
    <p class="text-lg text-text-secondary leading-relaxed max-w-md">{description}</p>
  </div>
</div>
