---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import SocialProof from '../../components/SocialProof.astro';
import FeatureSection from '../../components/FeatureSection.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
  <Navbar />
  <Hero />
  <SocialProof />

  <!-- Feature Sections -->
  <section class="py-20 lg:py-32 bg-background" id="fonctionnalites">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <SectionHeading subtitle={t('features.subtitle')}>
        {t('features.heading')} <span class="text-gradient">Swoop</span>
      </SectionHeading>

      <div class="space-y-24 lg:space-y-32">
        <FeatureSection
          title={t('features.main.0.title')}
          description={t('features.main.0.description')}
          color="primary"
          screenContent="chat"
        />
        <FeatureSection
          title={t('features.main.1.title')}
          description={t('features.main.1.description')}
          color="secondary"
          reverse={true}
          screenContent="deals"
        />
        <FeatureSection
          title={t('features.main.2.title')}
          description={t('features.main.2.description')}
          color="accent"
          screenContent="map"
        />
      </div>
    </div>
  </section>

  <BentoGrid />
  <HowItWorks />
  <Testimonials />
  <FAQ />
  <FinalCTA />
  <Footer />

  <script>
    import '../../scripts/animations';
  </script>
</Layout>
